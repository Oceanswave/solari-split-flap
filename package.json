{
  "name": "@oceanswave/solari-split-flap",
  "version": "1.0.1",
  "description": "A realistic split-flap (Solari board) display component for React + TypeScript. Cycles through quotes with authentic mechanical flip animations and synthesised click sounds.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run lint && npm run build",
    "dev": "open demo/index.html",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "biome ci src/ && tsc --noEmit && vitest run"
  },
  "keywords": [
    "solari",
    "split-flap",
    "flip-board",
    "departure-board",
    "react",
    "typescript",
    "component",
    "animation",
    "css3",
    "web-audio"
  ],
  "author": "Sean <sean@baristalabs.io>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Oceanswave/solari-split-flap.git"
  },
  "homepage": "https://github.com/Oceanswave/solari-split-flap#readme",
  "bugs": {
    "url": "https://github.com/Oceanswave/solari-split-flap/issues"
  }
}
