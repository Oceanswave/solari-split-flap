{
  "name": "solari-split-flap",
  "version": "1.2.0",
  "description": "A realistic split-flap (Solari board) display component for React + TypeScript. Cycles through quotes with authentic mechanical flip animations and synthesised click sounds.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/",
    "demo/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run lint && npm run build",
    "dev": "open demo/index.html",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "ci": "biome ci src/ && tsc --noEmit"
  },
  "keywords": [
    "solari",
    "split-flap",
    "flip-board",
    "departure-board",
    "react",
    "typescript",
    "component",
    "animation",
    "css3",
    "web-audio"
  ],
  "author": "Sean <sean@baristalabs.io>",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.2"
  },
  "repository": {
    "type": "git",
    "url": ""
  }
}
